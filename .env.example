# =========================================
# ENVIRONMENT VARIABLES (EXAMPLE VALUES ONLY)
# =========================================
# IMPORTANT:
# All values in this file are examples only.
# Copy this file to .env and replace with real credentials.

# =========================================
# SERVER CONFIGURATION
# =========================================

PORT=3000


# =========================================
# DATABASE CONFIGURATION (PRISMA - MYSQL)
# =========================================
# Required by Prisma

# MySQL connection string
DATABASE_URL="mysql://user:password@localhost:3306/database_name"

# Optional: used by application layer if needed
DB_HOST=localhost
DB_PORT=3306
DB_NAME=database_name
DB_USER=database_user
DB_PASSWORD=database_password


# =========================================
# JWT AUTHENTICATION
# =========================================

JWT_SECRET=your_jwt_secret
JWT_EXPIRES_IN=7d

JWT_REFRESH_SECRET=your_refresh_jwt_secret
JWT_REFRESH_EXPIRES_IN=30d


# =========================================
# OAUTH PROVIDERS
# =========================================

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret